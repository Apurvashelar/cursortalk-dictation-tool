{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Enterprise Voice Dictation",
  "version": "0.1.0",
  "identifier": "com.voiceflow.enterprise",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Enterprise Voice Dictation",
        "width": 1200,
        "height": 820,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": ["icons/icon.png"],
    "macOS": {
      "files": {
        "Frameworks/libonnxruntime.1.17.1.dylib": "target/debug/libonnxruntime.1.17.1.dylib",
        "Frameworks/libsherpa-onnx-c-api.dylib": "target/debug/libsherpa-onnx-c-api.dylib"
      }
    }
  }
}
