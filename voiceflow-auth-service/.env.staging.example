DATABASE_URL=postgres://voiceflow:REPLACE_ME@YOUR_RDS_ENDPOINT:5432/voiceflow_auth
AUTH_BIND_ADDR=127.0.0.1:4000
AUTH_TOKEN_TTL_HOURS=720
CORS_ALLOWED_ORIGIN=http://localhost:1420
RUST_LOG=info,voiceflow_auth_service=debug,tower_http=info

VOICEFLOW_DEMO_ORG_NAME=VoiceFlow Demo
