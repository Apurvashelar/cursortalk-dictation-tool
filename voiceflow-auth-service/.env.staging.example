VOICEFLOW_DEMO_OWNER_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
VOICEFLOW_DEMO_OWNER_FIRST_NAME=Demo
VOICEFLOW_DEMO_OWNER_LAST_NAME=Owner
VOICEFLOW_DEMO_MEMBER_EMAIL=member@voiceflow.demo
VOICEFLOW_DEMO_MEMBER_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
